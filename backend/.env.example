# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ibh_models

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── App URL (used to build photo URLs served from /uploads) ──────────────────
# Locally defaults to http://localhost:4000 automatically.
# In production set this to your deployed backend URL.
APP_URL=http://localhost:4000

# ── Email (Nodemailer SMTP) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=IBH Company <noreply@ibhcompany.com>
ADMIN_EMAIL=admin@ibhcompany.com

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
